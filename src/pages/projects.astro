---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Selected Project Highlights</div>
  </div>

  <HorizontalCard
    title="Global AI Agentic Data Mesh — Imdex"
    img="/post_img.webp"
    desc="Data Platform Lead establishing the platform, team and operating model; overseeing architecture and delivery across Kubernetes, Snowflake, Kafka, Airflow and DBT."
    url="/cv"
    badge="2026"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Rooftop Solar CSIP Data Ingestion / DER Virtual Power Plant — Synergy"
    img="/post_img.webp"
    desc="Data Architect for residential solar inverter telemetry ingestion, bitemporal XTDB datastore, OT cloud design, PKI/security, DAPR microservices and Azure Databricks forecasting."
    url="/cv"
    badge="2025–2026"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Environment Online Program — WA Dept of Water &amp; Environmental Regulation"
    img="/post_img.webp"
    desc="Architecture leadership across Dynamics 365/Power Platform CRM, integration and data workstreams; guardrails, ADRs and integration patterns for digital government services."
    url="/cv"
    badge="2025–2026"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="FinOps Cloud Cost Optimisation — Department of Education WA"
    img="/post_img.webp"
    desc="Multi-cloud FinOps optimisation across Azure/AWS/Oracle resulting in ~75% reduction in billed costs. Designed governance processes and reporting framework."
    url="/cv"
    badge="2024"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="APAC IT Modernization — Club Assist"
    img="/post_img.webp"
    desc="Principal Integration Architect for D365 CE/FO implementation, 20+ external supply-chain integrations, and BizTalk to Azure Integration Services upgrade across a five-person integration stream."
    url="/cv"
    badge="2020–2023"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Cloud + OT/IoT Portfolio — South32"
    img="/post_img.webp"
    desc="Cloud Architect for capital portfolio re-architecture to cloud and IoT Edge reporting for SCADA/OT sensor data across multiple mining systems."
    url="/cv"
    badge="2018–2020"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Digital Banking Delivery + Royal Commission Remediation — Bankwest"
    img="/post_img.webp"
    desc="Engineering Manager/Product Owner/Scrum Master leading squads across payments, mobile account tools, online lending, CRM/branch systems and Royal Commission remediation."
    url="/cv"
    badge="2017–2018"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="FinTech Cloud &amp; Credit Platforms — Fair Go Finance"
    img="/post_img.webp"
    desc="Founded the IT team and delivered Azure PaaS/microservices, Fasti online credit decisioning, customer portal, Viso data warehouse, Annie risk analytics and reusable scorecard/email services."
    url="/cv"
    badge="2015–2017"
  />
  <div class="divider my-0"></div>

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Earlier Projects</div>
  </div>
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Online Annuities + Adviser Platforms — Challenger (Sydney)"
    img="/post_img.webp"
    desc="Architect/Development Manager for challenger.com.au and fidante.com.au — MVC sites and quote/CRM/annuity systems integrating ADFS/WIF, NServiceBus/SOA, Salesforce and actuarial pricing."
    url="/cv"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Underwriting Platform — Beazley (London)"
    img="/post_img.webp"
    desc="Senior Developer on Beazley Trade v3.0 writing over $1B in policies/year: BDD, Monorail MVC, BizTalk/NServiceBus/WCF, SharePoint DMS, WPF add-ins and rules/workflow integration."
    url="/cv"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="ITV.com — Technical Architect (London)"
    img="/post_img.webp"
    desc="Technical Architect for ITV.com, the third largest website in the UK — broadband video streaming and CMS publishing platform."
    url="/cv"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Reuters 3000 Xtra — Software Engineer (London)"
    img="/post_img.webp"
    desc="Software Engineer for the Reuters 3000 Xtra hosted trading and Citrix platform."
    url="/cv"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Transperth / Transwa — Software Engineer (Perth, WA)"
    img="/post_img.webp"
    desc="Software Engineer for transperth.wa.gov.au and transwa.wa.gov.au — rail booking, ticketing and transport websites."
    url="/cv"
  />
</BaseLayout>
