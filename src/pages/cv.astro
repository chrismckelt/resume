---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    <p class="clear-both pb-px">
      Enterprise Solution Architect with 25+ years' experience leading the
      delivery of strategic initiatives across digital &amp; data products.
      Multi-cloud certified, customer focused and an independent advisor aligned
      to your success.
    </p>
    <br />
    <p class="clear-both pb-px">
      Architecture leadership for integration and cloud delivery in large,
      distributed organisations. Systems integration across enterprise platforms
      (CRM/ERP/data) using proven integration patterns and scalable designs.
      Azure/AWS/GCP architecture: landing zones, networking, identity, private
      connectivity, governance and cost management controls.
    </p>
    <br />
    <p class="clear-both pb-px">
      Delivery leadership: guiding engineers, setting standards, and ensuring
      design-to-build traceability. Engagement methods: discovery workshops,
      design thinking, and rapid PoCs to validate assumptions and reduce
      delivery risk. Agile and DevOps: CI/CD, Infrastructure-as-Code
      (Terraform), and modern engineering practices.
    </p>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>Microsoft Azure Solution Architecture Expert (AZ-303, AZ-304), Azure Fundamentals (AZ-900); PL-900</li>
    <li>AB100 - AI Business Solution Architect</li>
    <li>TOGAF 9.1 Certified</li>
    <li>FinOps Certified Engineer</li>
    <li>AWS Certified Cloud Practitioner</li>
    <li>Google Cloud Certified (Solution Architect)</li>
    <li>Certified Scrum Master (CSM)</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Technology &amp; Domains</div>
  </div>

  <div class="mb-10 text-justify">
    <p class="mb-2"><strong>Cloud:</strong> Azure (AKS/Kubernetes, App Services/Functions, Networking, Identity, Private Endpoints), AWS, GCP</p>
    <p class="mb-2"><strong>Integration:</strong> API-led integration, event-driven architecture, Kafka, Azure Integration Services, iPaaS/middleware patterns, DAPR</p>
    <p class="mb-2"><strong>Data &amp; Analytics:</strong> Databricks/Spark, Snowflake, Airflow, DBT, SQL, XTDB/bi-temporal data, operational data platforms</p>
    <p class="mb-2"><strong>DevOps/IaC:</strong> Azure DevOps, CI/CD, Terraform, Git, observability (APM/logging)</p>
    <p class="mb-2"><strong>Languages/Scripting:</strong> C#, Python, Go, TypeScript/JavaScript, Java, Kotlin, C/C++</p>
    <p class="mb-2"><strong>Frameworks:</strong> Arc42, TOGAF, Zachman, SABSA, COBIT, BABOK</p>
    <p class="mb-2"><strong>Modelling:</strong> ArchiMate, UML, BPMN, Event Modelling, Event Storming, Risk Storming, Wardley Mapping</p>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">

    <TimeLineElement
      title="Program Solution Architect (Contract) — Imdex"
      subtitle="2026 – Present | Perth, WA"
    >
      Architecture of a Global Agentic Data Mesh Platform. Multi-cloud design,
      Snowflake-based with AKS AI/ML workloads. Data Platform Lead establishing
      the platform, team and operating model; overseeing architecture and
      delivery across Kubernetes, Snowflake, Kafka, Airflow and DBT.
    </TimeLineElement>

    <TimeLineElement
      title="Program Solution Architect (Contract) — WA Department of Water and Environmental Regulation"
      subtitle="2025 – 2026 | Perth, WA | Engagement via Broadreach"
    >
      Architecture leadership across multiple squads delivering digital services
      and integrations on Microsoft cloud platforms (Environment Online program).
      Owned solution architecture across CRM (Dynamics 365/Power Platform),
      integration and data workstreams. Led discovery and design workshops;
      translated complex requirements into target-state designs, integration
      patterns and transition roadmaps. Established architecture guardrails,
      patterns and decision records (ADRs).
    </TimeLineElement>

    <TimeLineElement
      title="Cloud Data / Solution Architect (Contract) — Synergy"
      subtitle="2025 – 2026 | Perth, WA | Engagement via Cubility Consulting"
    >
      Solution and data technical architecture for a Virtual Power Plant
      platform ingesting rooftop solar inverter data from residential customers.
      Designed cloud-native architecture for large-volume inverter telemetry
      ingestion. Oversaw the London XTDB team implementing a HTAP bitemporal
      datastore for CSIP inverter records. Incorporated OT cloud hosting, PKI/
      security design, DAPR microservices and Azure Databricks forecasting into
      the target architecture.
    </TimeLineElement>

    <TimeLineElement
      title="Solution Architect — FinOps / Cloud Cost Optimisation (Contract) — Department of Education WA"
      subtitle="2024 | Perth, WA | Engagement via Broadreach"
    >
      Architecture and advisory engagement focused on multi-cloud FinOps cost
      optimisation and governance uplift. Led reconciliation and optimisation
      activities across Azure/AWS/Oracle resulting in ~75% reduction in billed
      costs. Designed FinOps processes, controls and reporting to sustain cost
      outcomes and improve forecasting/accountability.
    </TimeLineElement>

    <TimeLineElement
      title="Principal Solution Architect — Versent"
      subtitle="Dec 2022 – Jul 2023 | Perth, WA"
    >
      Architecture leadership across cloud migration and integration
      modernisation engagements during Telstra buyout. Architecture review and
      recommendations for an ASX-listed mortgage broking aggregator across AWS
      landing zones. Program design to migrate from MuleSoft to AWS
      cloud-native services for Curtin University. Facilitated discovery
      workshops and presented architecture decisions to senior stakeholders and
      governance forums.
    </TimeLineElement>

    <TimeLineElement
      title="Practice Lead — Applications, Integration &amp; Infrastructure — Insight (APAC)"
      subtitle="Jan 2020 – Jan 2023 | Perth, WA"
    >
      Led architecture and delivery across cloud and integration programs,
      combining technical leadership with commercial accountability. Principal
      Integration Architect for Club Assist APAC IT Modernization: D365 CE/FO
      implementation, 20+ supply-chain integrations, BizTalk to Azure
      Integration Services migration, and integration-stream leadership across
      a five-person team.
    </TimeLineElement>

    <TimeLineElement
      title="Cloud Solutions Architect — Velrada"
      subtitle="Nov 2018 – Jan 2020 | Perth, WA"
    >
      Solution architecture and technical leadership across pre-sales, design
      and delivery. Designed and delivered Azure IoT Edge data pipelines and
      MLOps patterns for industrial/mining contexts. Cloud Architect for South32
      initiatives including capital portfolio cloud re-architecture and IoT Edge
      reporting for SCADA/OT sensor data.
    </TimeLineElement>

    <TimeLineElement
      title="Engineering Manager / Product Owner / Scrum Master — Bankwest"
      subtitle="Nov 2017 – Dec 2018 | Perth, WA"
    >
      Delivery leadership across customer and internal platforms during agile
      transformation. Led multi-disciplinary squads delivering payments, digital
      account tools, online lending, and CRM/branch operations. Balanced
      regulatory remediation (Royal Commission) with forward delivery.
    </TimeLineElement>

    <TimeLineElement
      title="Head of Information Technology — Fair Go Finance (FinTech Services Australia)"
      subtitle="May 2015 – Nov 2017 | Perth, WA"
    >
      Established and led the IT function covering architecture, delivery and
      operations. Owned technology strategy and delivery; secured cloud
      sponsorship funding and drove cloud adoption. Delivered Fasti online
      credit decisioning, customer portal, Viso Azure SQL data warehouse, Annie
      credit-risk analytics and reusable scorecard/email services.
    </TimeLineElement>

    <TimeLineElement
      title="Earlier Career"
      subtitle="Pre-2015"
    >
      <strong>Challenger (Sydney)</strong> — Technology Lead for challenger.com.au and fidante.com.au online annuity/adviser channels.
      <br />
      <strong>Beazley (London)</strong> — Senior Developer on underwriting platform writing over $1B policies/year.
      <br />
      <strong>ITV (London)</strong> — Technical Architect for ITV.com, third largest website in the UK.
      <br />
      <strong>Reuters (London)</strong> — Software Engineer for Reuters 3000 Xtra hosted trading/Citrix platform.
      <br />
      <strong>Transperth (WA)</strong> — Software Engineer for transperth.wa.gov.au and transwa.wa.gov.au.
    </TimeLineElement>

  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Bachelor of Commerce — Information Systems and Marketing (Double Major)"
      subtitle="Curtin University, Perth WA"
    />
    <TimeLineElement
      title="Data Science Specialization (Certificate)"
      subtitle="Johns Hopkins University"
    />
    <TimeLineElement
      title="Ongoing Professional Development"
      subtitle="Distributed systems, integration patterns, DDD, CQRS/event sourcing"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Contact</div>
  </div>
  <div class="mb-10">
    <p>Email: <a class="link" href="mailto:chris@smarttechventures.au">chris@smarttechventures.au</a></p>
    <p>LinkedIn: <a class="link" href="https://linkedin.com/in/chrismckelt" target="_blank">linkedin.com/in/chrismckelt</a></p>
    <p>GitHub: <a class="link" href="https://github.com/chrismckelt" target="_blank">github.com/chrismckelt</a></p>
    <p>References available on request.</p>
  </div>

</BaseLayout>
