---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-5xl font-bold">I'm Chris McKelt</div>
    <div class="text-3xl py-3 font-bold">Fractional CTO | Architect | Forward Deployed Engineer</div>
    <div class="py-2">
      <text class="text-lg">
        Enterprise Solution Architect with 25+ years' experience leading
        strategic initiatives across digital &amp; data products. Multi-cloud
        certified, customer focused, and an independent advisor aligned to your
        success.
      </text>
    </div>
    <div class="mt-8">
      <a
        class="btn"
        href="https://www.linkedin.com/in/chrismckelt/"
        target="_blank"
      >
        Let's connect!</a
      >
      <a
        href="https://github.com/chrismckelt"
        target="_blank"
        class="btn btn-outline ml-5"
      >
        GitHub
      </a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Recent Roles {"</>"}</div>
  </div>
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Program Solution Architect — Imdex"
    img="/post_img.webp"
    desc="2026–Present · Global Agentic Data Mesh Platform. Multi-cloud design, Snowflake-based with AKS AI/ML workloads, Kafka, Airflow and DBT."
    url="/cv"
    badge="CURRENT"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Program Solution Architect — WA Dept of Water & Environmental Regulation"
    img="/post_img.webp"
    desc="2025–2026 · Architecture leadership across Dynamics 365/Power Platform, integration and data workstreams for the Environment Online program."
    url="/cv"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Cloud Data / Solution Architect — Synergy (Virtual Power Plant)"
    img="/post_img.webp"
    desc="2025–2026 · Cloud-native architecture for rooftop solar inverter telemetry ingestion, bitemporal XTDB datastore, DAPR microservices and Azure Databricks forecasting."
    url="/cv"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Solution Architect FinOps — Department of Education WA"
    img="/post_img.webp"
    desc="2024 · Multi-cloud FinOps cost optimisation across Azure/AWS/Oracle — ~75% reduction in billed costs."
    url="/cv"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Principal Solution Architect — Versent"
    img="/post_img.webp"
    desc="Dec 2022 – Jul 2023 · Cloud migration and integration modernisation including AWS landing zones for ASX-listed clients and MuleSoft-to-AWS migration for Curtin University."
    url="/cv"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Practice Lead — Insight (APAC)"
    img="/post_img.webp"
    desc="Jan 2020 – Jan 2023 · Architecture and delivery leadership. Principal Integration Architect for Club Assist APAC IT Modernization — D365, 20+ integrations, BizTalk to Azure Migration."
    url="/cv"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Engineering Manager / Product Owner / Scrum Master — Bankwest"
    img="/post_img.webp"
    desc="Nov 2017 – Dec 2018 · Led squads delivering payments, digital account tools, online lending, CRM/branch systems and Royal Commission remediation."
    url="/cv"
  />
</BaseLayout>
